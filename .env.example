# ─────────────────────────────────────────────────────────────
# Vidya Ashram Classes — Environment variables
# Copy this file to `.env` and fill in your real Supabase values.
# The site runs fully without these (uses elegant placeholder content);
# they are only needed for the CMS / Admin portal and media uploads.
# ─────────────────────────────────────────────────────────────

# Public (safe to expose to the browser)
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only secret (NEVER expose to the client). Used by admin API routes.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# The email that will own the admin account (create via Supabase Auth dashboard)
ADMIN_EMAIL="jaykumar2470f@gmail.com"
