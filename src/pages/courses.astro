---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Courses from '../components/react/Courses.tsx';
import Admission from '../components/sections/Admission.astro';
import Contact from '../components/react/Contact.tsx';
import Icon from '../components/Icon.astro';
import { courses, site } from '../content/site';

const trust = ['Small batches', 'Weekly tests', 'Senior faculty', 'Personal mentoring'];
---
<Base title="Courses | Vidya Ashram Classes, Hajipur" description="JEE, NEET, Foundation and Board Class programmes at Vidya Ashram Classes, Hajipur, Vaishali.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative bg-green text-white overflow-hidden">
      <div class="arc"></div>
      <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-black/10 to-transparent pointer-events-none"></div>

      <div class="container-x relative z-10 pt-28 sm:pt-32 pb-28 sm:pb-36 lg:pb-44">
        <div class="grid lg:grid-cols-12 gap-10 items-center">
          <div class="lg:col-span-7">
            <p class="eyebrow text-white/80 reveal">Programmes in {site.location}</p>
            <h1 class="font-display d-hero mt-5 reveal" data-delay="60">Choose the track.<br />We take care of the <span class="text-gold">rank.</span></h1>
            <p class="mt-6 max-w-xl text-white/85 text-lg leading-relaxed reveal" data-delay="120">
              Four focused programmes for JEE, NEET, Foundation and Boards. Each one is built around small batches, senior faculty and a steady rhythm of tests.
            </p>
            <div class="mt-8 flex flex-wrap gap-4 reveal" data-delay="180">
              <a href="#admission" class="btn btn-white">Book a demo class</a>
              <a href="#courses" class="btn btn-dark"><Icon name="chevron" class="w-4 h-4" />Browse programmes</a>
            </div>
            <div class="mt-9 flex flex-wrap gap-x-6 gap-y-3 reveal" data-delay="240">
              {trust.map((t) => (
                <span class="flex items-center gap-2 text-sm text-white/75"><Icon name="check" class="w-4 h-4 text-gold" />{t}</span>
              ))}
            </div>
          </div>

          <!-- Track quick-cards -->
          <div class="lg:col-span-5 grid grid-cols-2 gap-4 reveal" data-delay="160">
            {courses.map((c) => (
              <a href="#courses" class="rounded-2xl p-5 bg-white text-ink card-hover" style="box-shadow:0 16px 40px rgba(8,63,32,0.22);">
                <span class="tag tag-orange">{c.category}</span>
                <h3 class="font-display font-bold text-navy text-lg mt-3">{c.name}</h3>
                <p class="text-xs text-body mt-1">{c.tag2}</p>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- curved blue base flows into the courses section -->
      <div class="absolute inset-x-0 bottom-0 h-20 bg-blue" style="clip-path: ellipse(80% 100% at 50% 100%);"></div>
    </section>

    <Courses client:visible />
    <Admission />
    <Contact client:visible />
  </main>
  <Footer />
</Base>
