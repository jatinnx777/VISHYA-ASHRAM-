---
import { founder, site } from '../../content/site';
import Media from '../react/Media.tsx';
import Icon from '../Icon.astro';
---
<section id="about" class="section-pad bg-white overflow-hidden">
  <div class="container-x">
    <div class="max-w-2xl reveal">
      <p class="eyebrow text-green-deep">Our Story</p>
      <h2 class="font-display d-lg text-navy mt-3">{founder.headline}</h2>
    </div>

    <div class="mt-12 grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      <!-- Founder portrait card -->
      <div class="lg:col-span-4 reveal">
        <div class="relative rounded-3xl overflow-hidden" style="background:var(--color-green);">
          <span class="absolute right-4 top-4 z-10 w-10 h-10 rounded-lg" style="background:var(--color-gold);"></span>
          <Media client:visible path={founder.photo} label="Director photo" alt={founder.name} className="relative z-0 aspect-[4/5] w-full" />
        </div>
        <div class="mt-4">
          <h3 class="font-display font-bold text-xl text-navy">{founder.name}</h3>
          <p class="text-sm font-semibold text-green-deep">{founder.role}</p>
        </div>
      </div>

      <!-- Message + mission/vision -->
      <div class="lg:col-span-8">
        <div class="rounded-3xl p-8 md:p-10 reveal" style="background:var(--color-cloud); border-left:5px solid var(--color-green);">
          <Icon name="quote" class="w-9 h-9 text-green/40" />
          <div class="mt-3 space-y-4">
            {founder.paras.map((p) => (<p class="text-body leading-relaxed">{p}</p>))}
          </div>
        </div>

        <div class="mt-6 grid sm:grid-cols-2 gap-5">
          <div class="card p-6 reveal" style="box-shadow:var(--shadow-soft);">
            <span class="grid place-items-center w-11 h-11 rounded-xl text-green" style="background:var(--color-green-soft);"><Icon name="compass" class="w-6 h-6" /></span>
            <h4 class="font-display font-bold text-navy mt-4">Our Mission</h4>
            <p class="mt-2 text-body text-sm leading-relaxed">{founder.mission}</p>
          </div>
          <div class="card p-6 reveal" data-delay="60" style="box-shadow:var(--shadow-soft);">
            <span class="grid place-items-center w-11 h-11 rounded-xl text-blue" style="background:var(--color-blue-soft);"><Icon name="star" class="w-6 h-6" /></span>
            <h4 class="font-display font-bold text-navy mt-4">Our Vision</h4>
            <p class="mt-2 text-body text-sm leading-relaxed">{founder.vision}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Hajipur note strip -->
    <div class="mt-10 rounded-3xl p-7 md:p-9 flex flex-col md:flex-row md:items-center gap-5 justify-between reveal" style="background:linear-gradient(160deg,#0c6b34,#083f20);">
      <div class="relative z-10">
        <p class="font-display font-bold text-white text-xl md:text-2xl">Distance has nothing to do with education.</p>
        <p class="text-white/80 mt-1">Hajipur is not far from Patna, and now sound coaching is right here at home.</p>
      </div>
      <a href="#admission" class="btn btn-white shrink-0">Book a demo class</a>
    </div>
  </div>
</section>
