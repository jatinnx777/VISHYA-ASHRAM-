---
import AdmissionForm from '../react/AdmissionForm.tsx';
import Icon from '../Icon.astro';
---
<section id="admission" class="section-pad bg-white">
  <div class="container-x">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- left: pitch + illustration -->
      <div class="reveal">
        <h2 class="font-display d-lg text-navy">Enquire Now</h2>
        <p class="mt-3 text-body max-w-md">Leave your details and our admissions team will call you within 24 hours. Seats per batch are deliberately limited.</p>

        <div class="mt-8 flex items-center justify-center lg:justify-start">
          <div class="relative grid place-items-center w-52 h-52 rounded-full" style="background:var(--color-green-soft);">
            <Icon name="chat" class="w-24 h-24 text-green" />
            <span class="absolute -right-1 top-6 grid place-items-center w-14 h-14 rounded-full text-white" style="background:#25d366; box-shadow:0 12px 30px rgba(37,211,102,0.4);">
              <Icon name="wa" class="w-7 h-7" />
            </span>
          </div>
        </div>

        <ul class="mt-8 space-y-3">
          {['Free demo class with senior faculty', 'Personalised course and batch guidance', 'Scholarship test eligibility check'].map((t) => (
            <li class="flex items-center gap-3 text-ink">
              <span class="grid place-items-center w-6 h-6 rounded-full text-white shrink-0" style="background:var(--color-green);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>{t}
            </li>
          ))}
        </ul>
      </div>

      <!-- right: light-green form card, sticky on desktop -->
      <div class="lg:sticky lg:top-24 rounded-3xl p-7 md:p-9 reveal" style="background:var(--color-green-soft); box-shadow:var(--shadow-card);">
        <h3 class="font-display font-bold text-2xl text-navy mb-6">Admission enquiry</h3>
        <AdmissionForm client:visible />
      </div>
    </div>
  </div>
</section>
