---
import { whyChooseUs, site } from '../../content/site';
import Icon from '../Icon.astro';
---
<section id="why" class="relative section-pad bg-green text-white overflow-hidden">
  <div class="arc"></div>
  <div class="container-x relative z-10">
    <div class="max-w-2xl reveal">
      <h2 class="font-display d-lg">Why families in {site.location} choose us</h2>
      <p class="mt-3 text-white/80">Not the biggest name, the one that actually pays attention to your child.</p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {whyChooseUs.map((f, i) => (
        <article class="bg-white rounded-2xl p-7 text-ink reveal card-hover" data-delay={String(i * 60)} style="box-shadow:0 16px 40px rgba(8,63,32,0.18);">
          <span class="grid place-items-center w-12 h-12 rounded-xl text-green" style="background:var(--color-green-soft);">
            <Icon name={f.icon} class="w-6 h-6" />
          </span>
          <h3 class="font-display font-bold text-navy text-lg mt-5">{f.title}</h3>
          <p class="mt-2 text-body leading-relaxed">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
